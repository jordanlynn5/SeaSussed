{
  "manifest_version": 3,
  "name": "SeaSussed",
  "version": "0.1.0",
  "description": "Real-time seafood sustainability scores while you shop",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "microphone"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
