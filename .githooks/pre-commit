#!/usr/bin/env bash
# Pre-commit hook: run full verification suite before every commit.
# Install once with: git config core.hooksPath .githooks

set -e

BACKEND_DIR="$(git rev-parse --show-toplevel)/backend"

echo "--- pre-commit: mypy ---"
cd "$BACKEND_DIR" && uv run mypy .

echo "--- pre-commit: ruff ---"
uv run ruff check .

echo "--- pre-commit: pytest ---"
uv run pytest

echo "--- pre-commit: all checks passed ---"
